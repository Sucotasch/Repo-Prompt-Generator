{
  "name": "repo-prompt-generator-root",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w web",
    "build": "npm run build --workspaces",
    "start": "cd apps/web && npm run start",
    "lint": "npm run lint --workspaces"
  }
}
