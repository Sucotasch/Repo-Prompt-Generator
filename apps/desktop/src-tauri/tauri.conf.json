{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "repo-prompt-generator",
  "version": "0.1.0",
  "identifier": "com.sucotasch.repo-prompt-generator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Repo Prompt Generator",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}